    "docx": "^9.6.1",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "pptxgenjs": "^4.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.20.0",
    "prisma": "^7.4.2",
